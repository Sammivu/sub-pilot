# SubPilot Backend — Environment Variables
# Copy this to .env (never commit .env to git)

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=jdbc:postgresql://localhost:5432/subpilot
DATABASE_USERNAME=subpilot
DATABASE_PASSWORD=subpilot_secret

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 256 bits (32 chars). Generate with: openssl rand -base64 32
JWT_SECRET=change-this-to-a-secure-random-string-in-production

# ── Nomba Integration ─────────────────────────────────────────────────────────
NOMBA_BASE_URL=https://api.nomba.com/v1
NOMBA_ACCOUNT_ID=                    # From Nomba dashboard
NOMBA_CLIENT_ID=                     # From Nomba dashboard
NOMBA_CLIENT_SECRET=                 # From Nomba dashboard
NOMBA_MOCK_MODE=true                 # Set to false once keys are ready

# ── Email (Resend recommended) ────────────────────────────────────────────────
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USERNAME=resend
MAIL_PASSWORD=                       # Resend API key
MAIL_FROM=noreply@subpilot.co
MAIL_FROM_NAME=SubPilot

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_BASE_URL=http://localhost:5173  # Set to Netlify URL in production

# ── Billing Engine ────────────────────────────────────────────────────────────
BILLING_JOB_ENABLED=true

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
